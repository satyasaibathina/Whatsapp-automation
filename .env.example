# ══════════════════════════════════════════════════════════════════
#  .env.example — GitHub Secrets Reference
#  Copy this list to GitHub → Settings → Secrets → Actions
#  (DO NOT put real values here — this file is safe to commit)
# ══════════════════════════════════════════════════════════════════

# ── Oracle VPS WhatsApp Service ───────────────────────────────────
WA_SERVICE_URL=http://<YOUR_VPS_IP>:3000
WA_API_KEY=WHIZZARD_SECRET_API_KEY_2026

# ── WhatsApp Group & Tagging ──────────────────────────────────────
WA_GROUP_ID=<group-id>@g.us
WA_TAG_PERSON=91XXXXXXXXXX
WA_TAG_PERSON_ALT=91XXXXXXXXXX
WA_TAGS_MLL_VENDOR=91XXXXXXXXXX,91XXXXXXXXXX
WA_TAGS_WZ_VENDOR=91XXXXXXXXXX,91XXXXXXXXXX
WA_TAGS_MLL_EXPENSE=91XXXXXXXXXX,91XXXXXXXXXX
WA_TAGS_WZ_EXPENSE=91XXXXXXXXXX,91XXXXXXXXXX

# ── Whizzard Platform ─────────────────────────────────────────────
WHIZZARD_MOBILE=<mobile>
WHIZZARD_PASSWORD=<password>

# ── LogiWhiz Platform ─────────────────────────────────────────────
LOGIWHIZ_USERNAME=<username>
LOGIWHIZ_PASSWORD=<password>

# ── SMTP Email Alerts ─────────────────────────────────────────────
SMTP_USER=<gmail>
SMTP_PASSWORD=<app-password>
TO_EMAIL=<recipient>
EMAIL_FROM=<sender>
